ANTHROPIC_API_KEY=sk-ant-...
# Optional. Override the chat model without a code change. Defaults to
# claude-sonnet-4-6 (primary) and claude-haiku-4-5-20251001 (fallback).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001
# Required to call GET /api/health. Send it in the x-healthcheck-secret header.
# If unset, /api/health is locked (returns 401).
HEALTHCHECK_SECRET=some-long-random-string
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
