ANTHROPIC_API_KEY=sk-ant-...
# Optional. Override the chat model without a code change. Defaults to
# claude-sonnet-4-6 (primary) and claude-haiku-4-5-20251001 (fallback).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001
# Required to call GET /api/health. Send it in the x-healthcheck-secret header.
# If unset, /api/health is locked (returns 401).
HEALTHCHECK_SECRET=some-long-random-string
# Signing secret for anonymous "try Myla before signup" chat tokens (HMAC).
# Server-side only — never expose. If unset, the anonymous path is disabled
# (/api/anon/start returns 500 and /api/chat rejects anon tokens).
ANON_CHAT_SECRET=another-long-random-string
# Shared-store rate limiting for /api/chat. Add the Upstash Redis integration
# from the Vercel Marketplace — it sets these automatically. (The Vercel KV
# names KV_REST_API_URL/KV_REST_API_TOKEN are also accepted as a fallback.) If
# unset, the limiter falls back to a per-instance in-memory store (local dev).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Re-engagement push notifications (APNs, token-based .p8 auth) ---
# Create an APNs Auth Key in the Apple Developer portal (Keys → +, enable
# "Apple Push Notifications service (APNs)"). All four are required to send;
# if any is unset, the send path no-ops cleanly (no pushes, no crashes).
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=1234567890
APNS_BUNDLE_ID=app.hey2am.ios
# Paste the .p8 contents. Literal \n escapes are accepted and normalized.
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----"
# Default APNs environment for newly-registered tokens when the client doesn't
# send one. Set to "sandbox" while testing dev (Xcode) builds; "production" for
# TestFlight/App Store. The sender self-heals a wrong guess on first send.
APNS_DEFAULT_ENVIRONMENT=production
# Optional build-time hint baked into the web bundle so a token registers with
# the right environment immediately (skips the self-heal round-trip).
NEXT_PUBLIC_APNS_ENVIRONMENT=production
# Gate for GET /api/push/test (the manual "send one test push" tool). Send it
# via x-push-test-secret header or ?key=. If unset, the route is locked (401).
PUSH_TEST_SECRET=another-long-random-string
